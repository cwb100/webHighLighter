{
  "manifest_version": 3,
  "name": "Web Highlighter",
  "version": "0.1.0",
  "description": "Highlight text on webpages with multiple colors and manage saved marks.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open highlighter console"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
